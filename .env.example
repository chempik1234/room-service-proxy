# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/roomservice_proxy

# gRPC Server Configuration
GRPC_PORT=50051

# Rate Limiting Configuration
RATE_LIMIT_RPS=100
RATE_LIMIT_WINDOW=60s
RATE_LIMIT_BURST=10

# Admin API Configuration
ADMIN_PORT=8080
ADMIN_API_KEY=your_secret_admin_api_key_here

# Feature Flags
ENABLE_AUTH=true
ENABLE_RATE_LIMIT=true

# Deployment Provider Configuration
# Options: "railway", "yandex", "docker"
DEPLOYMENT_PROVIDER=railway

# Railway Configuration (for auto-provisioning)
RAILWAY_TOKEN=
RAILWAY_PROJECT_ID=
RAILWAY_ENVIRONMENT_ID=

# Yandex Cloud Configuration (for Yandex deployment)
YANDEX_FOLDER_ID=
YANDEX_ZONE=ru-central1-a
YANDEX_SERVICE_ACCOUNT_KEY=path/to/service-account-key.json
YANDEX_SSH_KEY_PATH=path/to/ssh/key
