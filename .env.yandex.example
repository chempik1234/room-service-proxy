# Yandex Cloud Configuration
# Copy this to .env and fill in your Yandex Cloud credentials

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/roomservice_proxy

# Admin API
ADMIN_API_KEY=your-admin-api-key-here

# Deployment Provider: "railway", "yandex", or "docker"
DEPLOYMENT_PROVIDER=yandex

# Yandex Cloud Configuration
YANDEX_FOLDER_ID=your-folder-id
YANDEX_ZONE=ru-central1-a
YANDEX_SERVICE_ACCOUNT_KEY=path/to/service-account-key.json
YANDEX_SSH_KEY_PATH=path/to/ssh/key
YANDEX_HOST=your-instance-ip
YANDEX_USER=yandex

# Railway Configuration (if using Railway instead)
# RAILWAY_TOKEN=your-railway-token
# RAILWAY_PROJECT_ID=your-railway-project-id
# RAILWAY_ENVIRONMENT_ID=your-railway-environment-id